# Local Monday-demo values only. Keep production secrets elsewhere.

# App ports
API_GATEWAY_PORT=8080
GOVERNANCE_PORT=8081
WORKSPACE_PORT=8082
FRONTEND_PORT=4200
KEYCLOAK_PORT=8180
OPA_PORT=8181
ONLYOFFICE_PORT=8084
POSTGRES_PORT=5432
MONGODB_PORT=27017
REDIS_PORT=6379
KAFKA_PORT=9092
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# PostgreSQL
POSTGRES_DB=fos_governance
POSTGRES_USER=fos
POSTGRES_PASSWORD=fos
POSTGRES_URL=jdbc:postgresql://localhost:5432/fos_governance

# MongoDB
MONGODB_DATABASE=fos_workspace
MONGODB_URI=mongodb://localhost:27017/fos_workspace

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Keycloak
KEYCLOAK_ADMIN=fos_admin
KEYCLOAK_ADMIN_PASSWORD=FosLocalAdmin2026!
KEYCLOAK_REALM=fos
KEYCLOAK_BASE_URL=http://localhost:8180
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/fos
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/fos/protocol/openid-connect/certs
KEYCLOAK_WEBHOOK_SECRET=fos-local-keycloak-webhook-secret-2026

# OPA
OPA_URL=http://localhost:8181

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=fos-workspace
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# OnlyOffice
ONLYOFFICE_DOCUMENT_SERVER_URL=http://localhost:8084
ONLYOFFICE_PUBLIC_URL=http://localhost:8084
ONLYOFFICE_INTERNAL_URL=http://localhost:8084
ONLYOFFICE_BACKEND_PUBLIC_URL=http://host.docker.internal:8082
ONLYOFFICE_CALLBACK_BASE_URL=http://host.docker.internal:8082
ONLYOFFICE_URL=http://localhost:8084
ONLYOFFICE_JWT_SECRET=fos-local-onlyoffice-jwt-secret-2026-demo
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_HEADER=Authorization
ONLYOFFICE_JWT_IN_BODY=true
ALLOW_PRIVATE_IP_ADDRESS=true
ALLOW_META_IP_ADDRESS=true

# Gateway downstream URLs
API_GATEWAY_URL=http://localhost:8080
GOVERNANCE_URL=http://localhost:8081
WORKSPACE_URL=http://localhost:8082
CANONICAL_SERVICE_URL=http://localhost:8081
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Security/JWT
FOS_SECURITY_ENABLED=true
STORAGE_PROVIDER=minio
