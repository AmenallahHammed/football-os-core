DB_USER=fos
DB_PASS=fos
KEYCLOAK_ADMIN=change-me-admin-user
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-password
KEYCLOAK_WEBHOOK_SECRET=change-me-webhook
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/fos/protocol/openid-connect/certs

# Local LAN address of the machine running Docker.
# Use a real private IP such as 192.168.1.42, not localhost, when another
# container or device must call back to services exposed on this host.
HOST_LAN_IP=<my-real-ip>

# For hybrid dev with the backend running on the host, this keeps presigned
# storage URLs reachable from Dockerized OnlyOffice. Full Docker compose
# overrides the workspace service to use http://minio:9000 internally.
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://${HOST_LAN_IP}:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
OPA_URL=http://host.docker.internal:8181
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change-me-opensearch-password
ONLYOFFICE_JWT_SECRET=fos-onlyoffice-secret-key-change-in-production
ONLYOFFICE_JWT_HEADER=Authorization
ONLYOFFICE_JWT_IN_BODY=true

# Browser/frontend URL. The editor loads api.js from here:
# http://<HOST_LAN_IP>:8084/web-apps/apps/api/documents/api.js
ONLYOFFICE_PUBLIC_URL=http://${HOST_LAN_IP}:8084

# Backend/container URL for server-side calls to Document Server.
ONLYOFFICE_INTERNAL_URL=http://onlyoffice-documentserver

# Callback base URL reachable from inside the OnlyOffice container.
# Hybrid host-run backend: http://host.docker.internal:8080
# Full Docker compose overrides the workspace service to http://fos-gateway:8080.
ONLYOFFICE_CALLBACK_BASE_URL=http://host.docker.internal:8080

# Legacy alias kept for existing local scripts; new config reads
# ONLYOFFICE_PUBLIC_URL first.
ONLYOFFICE_URL=${ONLYOFFICE_PUBLIC_URL}

# Local development only: allow Document Server to fetch private/LAN URLs
# such as HOST_LAN_IP, host.docker.internal, minio, or fos-gateway.
ALLOW_PRIVATE_IP_ADDRESS=true
ALLOW_META_IP_ADDRESS=true
