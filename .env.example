# ---------------------------------------------------------------------------
# Full Docker mode (docker compose up -d)
# ---------------------------------------------------------------------------
POSTGRES_USER=fos
POSTGRES_PASSWORD=fos
KEYCLOAK_ADMIN=local-keycloak-admin
KEYCLOAK_ADMIN_PASSWORD=local-keycloak-admin-password
KEYCLOAK_WEBHOOK_SECRET=local-keycloak-webhook-secret
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/fos/protocol/openid-connect/certs
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Local host/IP used for browser-facing URLs in local development.
# Replace with your machine real LAN IP when you want browser-openable
# ONLYOFFICE document URLs from both the host and Docker containers.
HOST_LAN_IP=192.168.0.126

# Storage mode:
# - noop  => metadata-only local development (no real object storage)
# - minio => real uploads/downloads and OnlyOffice editing
STORAGE_PROVIDER=minio
# Backend container endpoint (fos-net) used for direct MinIO operations.
MINIO_ENDPOINT=http://minio:9000
# Public endpoint used in presigned URLs consumed by browser and ONLYOFFICE.
MINIO_PUBLIC_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fos-workspace
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Hybrid host-backend mode can use a host-reachable OPA URL.
# Full Docker mode uses compose-internal http://opa:8181 directly.
OPA_URL=http://localhost:8181
OPENSEARCH_INITIAL_ADMIN_PASSWORD=local-opensearch-admin-password
ONLYOFFICE_JWT_SECRET=local-onlyoffice-jwt-secret-32bytes-minimum
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_HEADER=Authorization
ONLYOFFICE_JWT_IN_BODY=true

# Browser/frontend URL. The editor loads api.js from here:
# http://<HOST_LAN_IP>:8084/web-apps/apps/api/documents/api.js
ONLYOFFICE_DOCUMENT_SERVER_URL=http://${HOST_LAN_IP}:8084
ONLYOFFICE_PUBLIC_URL=${ONLYOFFICE_DOCUMENT_SERVER_URL}

# Backend URL used by the OnlyOffice container when it downloads document bytes.
# Use the LAN gateway URL when you want the same generated document.url to be
# reachable from both Docker and the host browser for debugging.
ONLYOFFICE_BACKEND_PUBLIC_URL=http://${HOST_LAN_IP}:8080

# Backend/container URL for server-side calls to Document Server.
ONLYOFFICE_INTERNAL_URL=http://onlyoffice-documentserver

# Callback base URL reachable from inside the OnlyOffice container.
# Keep it aligned with ONLYOFFICE_BACKEND_PUBLIC_URL for browser-openable local debugging.
ONLYOFFICE_CALLBACK_BASE_URL=http://${HOST_LAN_IP}:8080

# Legacy alias kept for existing local scripts; new config reads
# ONLYOFFICE_DOCUMENT_SERVER_URL first.
ONLYOFFICE_URL=${ONLYOFFICE_DOCUMENT_SERVER_URL}

# Local development only: allow Document Server to fetch private/LAN URLs
# such as HOST_LAN_IP, host.docker.internal, minio, or fos-gateway.
ALLOW_PRIVATE_IP_ADDRESS=true
ALLOW_META_IP_ADDRESS=true

# ---------------------------------------------------------------------------
# Hybrid host-backend mode (.env.dev, docker-compose.infra.yml + mvn run)
# ---------------------------------------------------------------------------
# Keep ONLYOFFICE_BACKEND_PUBLIC_URL and ONLYOFFICE_CALLBACK_BASE_URL on the
# LAN gateway URL when you need document.url links to open from the host browser too.

# ---------------------------------------------------------------------------
# No-auth local overlay (docker-compose.noauth.yml)
# ---------------------------------------------------------------------------
# No extra env keys required here; the overlay sets FOS_SECURITY_ENABLED=false
# for selected services.
