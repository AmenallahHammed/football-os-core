# Hybrid host-backend mode template.
# Copy to .env.dev for local use. Keep .env.dev ignored and uncommitted.

POSTGRES_USER=fos
POSTGRES_PASSWORD=fos
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_WEBHOOK_SECRET=local-keycloak-webhook-secret
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/fos/protocol/openid-connect/certs
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Stable local hostname used for browser-facing URLs in local development.
# Add `127.0.0.1 football-os.local` to your Windows hosts file.
# Do not use changing LAN IPs like 192.168.x.x for stable local development.
LOCAL_PUBLIC_HOST=football-os.local

STORAGE_PROVIDER=noop
# Use STORAGE_PROVIDER=minio for real upload/download and OnlyOffice tests.
# In hybrid mode (backend on host), localhost:9000 reaches MinIO directly.
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://${LOCAL_PUBLIC_HOST}:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fos-workspace-dev

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
OPA_URL=http://localhost:8181

ONLYOFFICE_DOCUMENT_SERVER_URL=http://${LOCAL_PUBLIC_HOST}:8084
ONLYOFFICE_PUBLIC_URL=${ONLYOFFICE_DOCUMENT_SERVER_URL}
ONLYOFFICE_BACKEND_PUBLIC_URL=http://${LOCAL_PUBLIC_HOST}:8080
ONLYOFFICE_INTERNAL_URL=http://onlyoffice-documentserver
ONLYOFFICE_CALLBACK_BASE_URL=http://${LOCAL_PUBLIC_HOST}:8080
ONLYOFFICE_JWT_SECRET=local-onlyoffice-jwt-secret-32bytes-minimum
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_HEADER=Authorization
ONLYOFFICE_JWT_IN_BODY=true

ALLOW_PRIVATE_IP_ADDRESS=true
ALLOW_META_IP_ADDRESS=true
